            border-radius: 30px;
            font-size: clamp(12px, 2vw, 16px);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: clamp(15px, 2vw, 20px);
            animation: pulsebadge 2s ease-in-out infinite;
            color: #ffffff;
        }

        @keyframes pulsebadge {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .giftcard-main-heading {
            font-size: clamp(32px, 6vw, 56px);
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: clamp(10px, 1.5vw, 15px);
            text-transform: uppercase;
            letter-spacing: 1px;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.3);
            color: #ffffff;
        }

        .giftcard-discount-highlight {
            display: inline-block;
            background: #ffffff;
            color: #c0392b;
            padding: clamp(8px, 1.5vw, 15px) clamp(20px, 3vw, 35px);
            border-radius: 10px;
            font-size: clamp(40px, 7vw, 70px);
            font-weight: 800;
            line-height: 1;
            margin: clamp(15px, 2vw, 20px) 0;
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            transform: rotate(-2deg);
        }

        .giftcard-subheading {
            font-size: clamp(18px, 3vw, 28px);
            font-weight: 600;
            margin-bottom: clamp(20px, 3vw, 30px);
            line-height: 1.3;
            color: #ffffff;
        }

        .giftcard-steps-container {
            display: flex;
            gap: clamp(15px, 2vw, 25px);
            justify-content: center;
            align-items: center;
            margin: clamp(25px, 3vw, 35px) 0;
            flex-wrap: wrap;
        }

        .giftcard-step-box {
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 15px;
            padding: clamp(15px, 2vw, 25px) clamp(20px, 3vw, 30px);
            min-width: clamp(150px, 20vw, 200px);
            transition: transform 0.3s ease, background 0.3s ease;
        }

        .giftcard-step-box:hover {
            transform: translateY(-5px);
            background: rgba(255, 255, 255, 0.25);
        }

        .giftcard-step-number {
            display: inline-block;
            width: clamp(30px, 4vw, 40px);
            height: clamp(30px, 4vw, 40px);
