            color: #c0392b;
            border-radius: 50%;
            font-size: clamp(16px, 2.5vw, 20px);
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto clamp(8px, 1.5vw, 12px);
        }

        .giftcard-step-text {
            font-size: clamp(14px, 2vw, 18px);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #ffffff;
        }

        .giftcard-code-box {
            display: inline-block;
            background: #ffffff;
            color: #c0392b;
            padding: clamp(12px, 2vw, 18px) clamp(25px, 4vw, 40px);
            border-radius: 10px;
            font-size: clamp(20px, 4vw, 32px);
            font-weight: 800;
            letter-spacing: 3px;
            border: 3px dashed #c0392b;
            margin: clamp(15px, 2vw, 20px) 0;
            box-shadow: 0 6px 15px rgba(0,0,0,0.2);
        }

        .giftcard-cta-button {
            display: inline-block;
            background: #ffffff;
            color: #c0392b;
            padding: clamp(15px, 2.5vw, 20px) clamp(35px, 5vw, 50px);
            border-radius: 50px;
            font-size: clamp(16px, 2.5vw, 22px);
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-decoration: none;
            margin: clamp(20px, 3vw, 30px) 0 clamp(10px, 2vw, 15px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
            border: 3px solid #ffffff;
        }

        .giftcard-cta-button:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 12px 35px rgba(0,0,0,0.4);
            background: #2d5a3d;
            color: #ffffff;
        }

        .giftcard-cta-button:active {
            transform: translateY(-1px);
        }

        .giftcard-disclaimer {
            font-size: clamp(12px, 2vw, 14px);
            font-weight: 600;
            margin-top: clamp(15px, 2vw, 20px);
            opacity: 0.95;
            color: #ffffff;
        }

        .giftcard-arrow {
            font-size: clamp(20px, 3vw, 28px);
            opacity: 0.7;
            color: #ffffff;
        }

        /* Mobile adjustments */
        @media (max-width: 768px) {
            .giftcard-steps-container {
                flex-direction: column;
            }

            .giftcard-step-box {
                width: 100%;
                max-width: 300px;
            }

            .giftcard-arrow {
                transform: rotate(90deg);
            }

            .giftcard-discount-highlight {
                transform: rotate(-1deg);
            }
        }
    </style>
</head>
<body>
    <section class="giftcard-promo-banner">
        <div class="giftcard-banner-container">
            <div class="giftcard-banner-content">
                
                
                <h1 class="giftcard-main-heading">Give the Gift of Greenery</h1>
                
                <div class="giftcard-discount-highlight">10% OFF</div>
                
                <h2 class="giftcard-subheading">All Gift Cards</h2>
                
                <div class="giftcard-steps-container">
                    <div class="giftcard-step-box">
                        <div class="giftcard-step-number">1</div>
                        <div class="giftcard-step-text">Choose Amount</div>
                    </div>
                    
                    <span class="giftcard-arrow">→</span>
                    
                    <div class="giftcard-step-box">
                        <div class="giftcard-step-number">2</div>
                        <div class="giftcard-step-text">Add to Cart</div>
                    </div>
                    
                    <span class="giftcard-arrow">→</span>
                    
                    <div class="giftcard-step-box">
                        <div class="giftcard-step-number">3</div>
                        <div class="giftcard-step-text">Use Code</div>
                    </div>
                </div>
                
                <div class="giftcard-code-box">GIFT10</div>
                
                <a href="/gift-card" class="giftcard-cta-button">Shop Gift Cards →</a>
                
                <p class="giftcard-disclaimer">*Limited time offer. Maximum 2 gift cards per customer at discounted rate.</p>
            </div>
        </div>
    </section>
</body>
</html>







